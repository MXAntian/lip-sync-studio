{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.lipsync.studio",
  "productName": "Lip Sync Studio",
  "directories": {
    "output": "dist"
  },
  "files": [
    "out/**/*",
    "package.json"
  ],
  "win": {
    "target": "dir",
    "extraResources": [
      {
        "from": "resources/",
        "to": "."
      }
    ]
  }
}
